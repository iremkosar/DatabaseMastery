@model List<ResultAboutDto>
<section class="section mt-85">
    <div class="container">
        <div class="text-center">
            <img class="mb-15" src="/templates/assets/imgs/template/icons/favicon.svg" alt="transp">
            <p class="font-md color-grey-700">Sektör Liderleri İçin Güvenilir Çözümler</p>
            <h2 class="color-brand-2 mb-65 mt-15">Ekibimizle Gurur Duyuyoruz<br class="d-none d-lg-block">ve her gün daha iyisi için çalışıyoruz.</h2>
        </div>
        <div class="row mt-50 align-items-center">
            <div class="col-xl-7 col-lg-6 mb-30">
                <div class="box-images-pround">
                    <div class="box-images">
                        <img class="img-main" src="/templates/assets/imgs/page/homepage1/img1.png" alt="transp">
                        <div class="image-2 shape-3"> <img src="/templates/assets/imgs/page/homepage1/icon1.png" alt="transp"></div>
                    </div>
                </div>
            </div>
            <div class="col-xl-5 col-lg-6 mb-30">
                <div class="box-info-pround">
                    @foreach(var item in Model) {
                    <h3 class="color-brand-2 mb-15">@item.Title</h3>
                    <p class="font-md color-grey-500">@item.Description</p>
                    }
                    <div class="mt-30">
                        <ul class="list-ticks">
                            <li>
                                <svg class="w-6 h-6 icon-16" fill="none" stroke="currentColor" viewbox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
                                </svg>Anlık takip sistemi
                            </li>
                            <li>
                                <svg class="w-6 h-6 icon-16" fill="none" stroke="currentColor" viewbox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
                                </svg>Operasyonel şeffaflık
                            </li>
                            <li>
                                <svg class="w-6 h-6 icon-16" fill="none" stroke="currentColor" viewbox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
                                </svg>Hızlı teslimat çözümleri
                            </li>
                            <li>
                                <svg class="w-6 h-6 icon-16" fill="none" stroke="currentColor" viewbox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
                                </svg>Ekip koordinasyonu
                            </li>
                            <li>
                                <svg class="w-6 h-6 icon-16" fill="none" stroke="currentColor" viewbox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
                                </svg>Güvenli veri paylaşımı
                            </li>
                            <li>
                                <svg class="w-6 h-6 icon-16" fill="none" stroke="currentColor" viewbox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
                                </svg>Performans ve süre analizi
                            </li>
                        </ul>
                    </div>
                    <div class="mt-30 text-start d-flex"> <a class="hover-up mr-10" href="#"> <img src="/templates/assets/imgs/template/appstore-btn.png" alt="transp"></a><a class="hover-up" href="#"> <img src="/templates/assets/imgs/template/google-play-btn.png" alt="transp"></a></div>
                </div>
            </div>
        </div>
    </div>
</section>
